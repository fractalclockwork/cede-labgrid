{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cede.local/schemas/lab.schema.json",
  "title": "CEDE lab configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "hosts", "serial", "paths", "i2c_matrix"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "hosts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev_host": { "$ref": "#/$defs/hostEntry" },
        "pi": { "$ref": "#/$defs/hostEntry" }
      },
      "required": ["dev_host"]
    },
    "labgrid": {
      "type": "object",
      "additionalProperties": false,
      "description": "Global LabGrid settings shared by all exporters.",
      "required": ["coordinator_address"],
      "properties": {
        "coordinator_address": {
          "type": "string",
          "minLength": 1,
          "description": "HOST:PORT of the labgrid-coordinator (e.g. 192.168.1.111:20408)."
        }
      }
    },
    "exporters": {
      "type": "array",
      "description": "LabGrid exporter definitions. Each entry provisions one gateway (Pi, BeagleBone, etc.) with its attached resources.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/exporterEntry" }
    },
    "serial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaults", "devices"],
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baud": { "type": "integer", "minimum": 300 },
            "newline": { "type": "string" },
            "timeout_s": { "type": "number", "exclusiveMinimum": 0 }
          },
          "required": ["baud", "newline", "timeout_s"]
        },
        "devices": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/serialDevice" },
          "minProperties": 1
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pico_build",
        "pico_uf2_glob",
        "uno_build",
        "uno_hex_glob",
        "logs_dir",
        "test_results_dir"
      ],
      "properties": {
        "pico_build": { "type": "string" },
        "pico_uf2_glob": { "type": "string" },
        "uno_build": { "type": "string" },
        "uno_hex_glob": { "type": "string" },
        "logs_dir": { "type": "string" },
        "test_results_dir": { "type": "string" },
        "lab_stack_pico_build": { "type": "string" },
        "lab_stack_pico_uf2_glob": { "type": "string" },
        "lab_stack_uno_build": { "type": "string" },
        "lab_stack_uno_hex_glob": { "type": "string" },
        "ssd1306_dual_pi_app": {
          "type": "string",
          "description": "Pi gateway application tree (Python) for ssd1306_dual."
        },
        "ssd1306_dual_pi_main_glob": {
          "type": "string",
          "description": "Glob for the Pi app entrypoint under ssd1306_dual_pi_app (e.g. main.py)."
        },
        "ssd1306_eyes_pi_app": {
          "type": "string",
          "description": "Pi gateway application tree (Python) for ssd1306_eyes."
        },
        "ssd1306_eyes_pi_main_glob": {
          "type": "string",
          "description": "Glob for the Pi app entrypoint under ssd1306_eyes_pi_app (e.g. main.py)."
        }
      }
    },
    "applications": {
      "type": "object",
      "description": "Maps application_id to path keys under paths.* for multi-target firmware products.",
      "additionalProperties": { "$ref": "#/$defs/applicationEntry" }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional metadata keyed by pi/pico/uno; compose with existing paths.* and serial.devices.* (no parallel rename).",
      "properties": {
        "pico": { "$ref": "#/$defs/targetMcu" },
        "uno": { "$ref": "#/$defs/targetMcu" },
        "pi": { "$ref": "#/$defs/targetGateway" }
      }
    },
    "i2c_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bus_hz", "probe_address", "pairs"],
      "properties": {
        "bus_hz": { "type": "integer", "minimum": 1000 },
        "probe_address": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "pairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/i2cPair" },
          "minItems": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "prefix": { "type": "string" }
      },
      "required": ["enabled"]
    },
    "raspberry_pi_bootstrap": {
      "$ref": "#/$defs/raspberryPiBootstrap"
    }
  },
  "$defs": {
    "hostEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role"],
      "properties": {
        "role": { "type": "string" },
        "repo_root": {
          "type": "string",
          "description": "Path on that host: Dev-Host = full repo checkout; Pi gateway = sparse rsync destination for lab/pi only (not a git clone). See lab/pi/scripts/sync_gateway_flash_deps.sh."
        },
        "ssh_host": { "type": "string" },
        "ssh_user": { "type": "string" }
      }
    },
    "serialDevice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fallback_globs"],
      "properties": {
        "by_id_glob": { "type": "string" },
        "fallback_globs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "applicationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pico": { "$ref": "#/$defs/applicationTargetPaths" },
            "uno": { "$ref": "#/$defs/applicationTargetPaths" },
            "pi": { "$ref": "#/$defs/applicationTargetPaths" }
          }
        }
      }
    },
    "applicationTargetPaths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths_build_key", "paths_artifact_glob_key"],
      "properties": {
        "paths_build_key": { "type": "string", "minLength": 1 },
        "paths_artifact_glob_key": { "type": "string", "minLength": 1 }
      }
    },
    "targetMcu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "paths", "serial_devices_key"],
      "properties": {
        "kind": { "const": "mcu" },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["build_key", "artifact_glob_key"],
          "properties": {
            "build_key": {
              "type": "string",
              "enum": ["pico_build", "uno_build", "lab_stack_pico_build", "lab_stack_uno_build"]
            },
            "artifact_glob_key": {
              "type": "string",
              "enum": ["pico_uf2_glob", "uno_hex_glob", "lab_stack_pico_uf2_glob", "lab_stack_uno_hex_glob"]
            }
          }
        },
        "serial_devices_key": {
          "type": "string",
          "enum": ["pico", "uno"]
        }
      }
    },
    "targetGateway": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "gateway" },
        "hosts_key": {
          "type": "string",
          "const": "pi",
          "description": "Reference entry under hosts for the Raspberry Pi gateway."
        },
        "notes": { "type": "string" }
      }
    },
    "i2cPairValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "controller"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["rpi_master_i2cdev_read"],
          "description": "Pi as Linux I2C master (i2cget) to the target MCU at probe_address."
        },
        "controller": {
          "type": "string",
          "enum": ["rpi"],
          "description": "Must be rpi for rpi_master_i2cdev_read (Pi drives SCL on the shared harness)."
        },
        "reg": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "Target register index for rpi_master_i2cdev_read (hello_lab uses 0)."
        },
        "expect_byte": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "Expected byte for rpi_master_i2cdev_read (hello_lab reg0 = 0xCE)."
        },
        "linux_bus": {
          "type": "integer",
          "minimum": 0,
          "description": "Override Pi Linux bus number; default is pair.linux_bus when mode is rpi_master_i2cdev_read."
        }
      }
    },
    "i2cPair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initiator", "target", "status"],
      "properties": {
        "initiator": {
          "type": "string",
          "enum": ["rpi", "pico", "uno"]
        },
        "target": {
          "type": "string",
          "enum": ["rpi", "pico", "uno"]
        },
        "status": {
          "type": "string",
          "enum": ["enabled", "n/a"]
        },
        "reason": { "type": "string" },
        "linux_bus": { "type": "integer", "minimum": 0 },
        "probe_address": {
          "type": "integer",
          "minimum": 8,
          "maximum": 119,
          "description": "7-bit address of target MCU as I2C slave on the shared harness (Pi reads)."
        },
        "notes": { "type": "string" },
        "validation": { "$ref": "#/$defs/i2cPairValidation" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "n/a" } },
            "required": ["status"]
          },
          "then": { "required": ["reason"] }
        },
        {
          "if": {
            "properties": { "status": { "const": "enabled" } },
            "required": ["status"]
          },
          "then": { "required": ["probe_address", "validation"] }
        }
      ]
    },
    "exporterEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "hostname", "resources"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Exporter name registered with the coordinator (labgrid-exporter --name)."
        },
        "hostname": {
          "type": "string",
          "minLength": 1,
          "description": "Short hostname for cloud-init."
        },
        "ssh_user": {
          "type": "string",
          "minLength": 1,
          "default": "pi",
          "description": "SSH user on the gateway (default: pi)."
        },
        "ssh_host": {
          "type": "string",
          "description": "SSH hostname or IP. Defaults to <hostname>.local (mDNS)."
        },
        "location": {
          "type": "string",
          "description": "LabGrid location tag for grouping resources (e.g. cede-lab-bench-1)."
        },
        "isolated": {
          "type": "boolean",
          "default": false,
          "description": "Enable LabGrid isolated mode (--isolated); forces SSH port forwarding for all resources."
        },
        "authorized_keys_file": {
          "type": "string",
          "description": "Dev-Host path to SSH public key(s) for passwordless first-boot SSH."
        },
        "timezone": {
          "type": "string",
          "default": "UTC"
        },
        "locale": {
          "type": "string",
          "default": "en_US.UTF-8"
        },
        "os_image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1,
              "description": "HTTPS URL or path to OS image (.img or .img.xz)."
            },
            "sha256": {
              "type": "string",
              "description": "Expected SHA256 of the downloaded image (hex)."
            },
            "cache_path": {
              "type": "string",
              "description": "Dev-Host path to cache the downloaded image."
            }
          },
          "required": ["url"]
        },
        "wifi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ssid": { "type": "string", "minLength": 1 },
            "regulatory_domain": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "psk": { "type": "string" },
            "psk_file": { "type": "string" }
          },
          "required": ["ssid"]
        },
        "resources": {
          "type": "array",
          "description": "Exported resource groups and their place bindings.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/exporterResource" }
        }
      }
    },
    "exporterResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "type", "match"],
      "properties": {
        "group": {
          "type": "string",
          "minLength": 1,
          "description": "LabGrid resource group name (e.g. cede-pico-port)."
        },
        "type": {
          "type": "string",
          "enum": ["USBSerialPort"],
          "description": "LabGrid resource type."
        },
        "match": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "minProperties": 1,
          "description": "udev match properties (e.g. ID_SERIAL_SHORT)."
        },
        "speed": {
          "type": "integer",
          "default": 115200,
          "description": "Baud rate (default 115200)."
        },
        "place": {
          "type": "string",
          "description": "LabGrid place name to create for this resource group."
        },
        "place_tags": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Tags to set on the place (e.g. board: pico)."
        }
      }
    },
    "raspberryPiBootstrap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostname": {
          "type": "string",
          "minLength": 1,
          "description": "Short hostname for cloud-init; align hosts.pi.ssh_host with <hostname>.local for mDNS."
        },
        "authorized_keys_file": {
          "type": "string",
          "description": "Dev-Host path to SSH public key(s) for passwordless first-boot SSH."
        },
        "os_image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1,
              "description": "HTTPS URL or path to Raspberry Pi OS Lite arm64 .img or .img.xz for rpi-imager."
            },
            "sha256": {
              "type": "string",
              "description": "Expected SHA256 for rpi-imager --sha256 (hex)."
            },
            "cache_path": {
              "type": "string",
              "description": "Optional Dev-Host path to cache the downloaded image."
            }
          },
          "required": ["url"]
        },
        "wifi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ssid": { "type": "string", "minLength": 1 },
            "regulatory_domain": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2,
              "description": "ISO 3166-1 alpha-2 for Wi‑Fi regulatory-domain in network-config (default US)."
            },
            "psk": {
              "type": "string",
              "description": "Wi-Fi passphrase (prefer psk_file for secrets)."
            },
            "psk_file": {
              "type": "string",
              "description": "Path to a file containing the passphrase (single line)."
            }
          },
          "required": ["ssid"]
        },
        "timezone": {
          "type": "string",
          "description": "e.g. UTC or America/New_York"
        },
        "locale": {
          "type": "string",
          "description": "e.g. en_US.UTF-8"
        },
        "labgrid": {
          "type": "object",
          "additionalProperties": false,
          "description": "LabGrid exporter provisioning via cloud-init. When present, first-boot installs labgrid in a venv, deploys the exporter config, and enables a systemd user service.",
          "required": ["coordinator_address", "pico_usb_serial_short", "uno_usb_serial_short"],
          "properties": {
            "coordinator_address": {
              "type": "string",
              "minLength": 1,
              "description": "HOST:PORT of the labgrid-coordinator (e.g. 192.168.1.111:20408)."
            },
            "exporter_name": {
              "type": "string",
              "minLength": 1,
              "description": "Public name for the exporter (defaults to the Pi hostname)."
            },
            "location": {
              "type": "string",
              "description": "LabGrid location tag for grouping resources (e.g. cede-lab-bench-1)."
            },
            "pico_usb_serial_short": {
              "type": "string",
              "minLength": 1,
              "description": "udev ID_SERIAL_SHORT for the Pico USB serial device."
            },
            "uno_usb_serial_short": {
              "type": "string",
              "minLength": 1,
              "description": "udev ID_SERIAL_SHORT for the Uno USB serial device."
            }
          }
        }
      }
    }
  }
}
